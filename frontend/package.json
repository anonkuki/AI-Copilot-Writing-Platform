{
  "name": "ai-plus-frontend",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "npm run build && electron-builder",
    "electron:start": "electron ."
  },
  "dependencies": {
    "@tiptap/core": "^2.2.0",
    "@tiptap/extension-collaboration": "^2.2.0",
    "@tiptap/extension-highlight": "^2.2.0",
    "@tiptap/extension-placeholder": "^2.2.0",
    "@tiptap/extension-task-item": "^2.2.0",
    "@tiptap/extension-task-list": "^2.2.0",
    "@tiptap/pm": "^2.2.0",
    "@tiptap/starter-kit": "^2.2.0",
    "@tiptap/vue-3": "^2.2.0",
    "axios": "^1.6.5",
    "pinia": "^2.1.7",
    "socket.io-client": "^4.7.4",
    "vue": "^3.5.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.17",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vue-tsc": "^3.2.5"
  },
  "build": {
    "appId": "com.aiplus.writer",
    "productName": "AI+作家助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
